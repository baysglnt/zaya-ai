# App
NEXT_PUBLIC_APP_URL=https://zaya.mn
NEXT_PUBLIC_APP_NAME="ZAYA AI"

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/zaya_ai"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL=https://zaya.mn
NEXTAUTH_SECRET="your-secret-here-min-32-chars-long-random"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Facebook OAuth
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# Anthropic Claude API
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-opus-4-5"

# QPay (Mongolian payment system)
QPAY_USERNAME="your-qpay-username"
QPAY_PASSWORD="your-qpay-password"
QPAY_INVOICE_CODE="ZAYA_AI_INVOICE"
QPAY_BASE_URL="https://merchant.qpay.mn/v2"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Admin
ADMIN_EMAIL="admin@zaya.mn"
ADMIN_SECRET="your-admin-secret"

# SEO
NEXT_PUBLIC_SITE_DESCRIPTION="ZAYA AI — Монголын хамгийн дэвшилтэт астрологи платформ"
